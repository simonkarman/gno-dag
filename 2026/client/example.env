NEXT_PUBLIC_KRMX_SERVER_URL='ws://localhost:8082/krmx?version=0.0.1'
NEXT_PUBLIC_LOCAL_DEVELOPMENT='true'
# ISO datetime when the game begins. Before this, players see the waiting screen.
# Set to a past date locally to skip the waiting screen while testing.
NEXT_PUBLIC_START_DATETIME='2026-06-15T10:00:00+02:00'

# --- Admin UI (/admin) — LOCAL ONLY ---
# The admin route is fully disabled unless ADMIN_PASSWORD is set. Never set this
# in production (Vercel). Locally it also needs GCS Application Default Credentials:
#   gcloud auth application-default login
ADMIN_PASSWORD='change-me'
GCS_BUCKET='gno-2026'
GCS_BLOB='state-dev.json'

PORT=8082
LOCAL_DEVELOPMENT=true
JSON_LOGGING=false

# Google Cloud Storage — persistent game state.
# Locally, authenticate with: gcloud auth application-default login
# Set the project explicitly: without it the GCP client probes the GCE metadata
# server to discover the project, which is unreachable locally and stalls ~5s.
GOOGLE_CLOUD_PROJECT=playground-simonkarman
GCS_BUCKET=gno-2026
# Use a different blob name locally to test without touching production state.
GCS_BLOB=state-dev.json

# ISO datetime when the game begins. Before this, players see the waiting screen.
START_DATETIME=2026-06-15T10:00:00+02:00
